%%{ init: { "theme": "base", "themeVariables": { "fontSize": "20px", "fontFamily": "Inter, sans-serif", "fontWeight": "700", "lineColor": "#6b7280" } } }%%
flowchart TD

    classDef user     fill:#dbeafe,stroke:#2563eb,color:#1e3a8a,font-weight:bold
    classDef auth     fill:#ede9fe,stroke:#7c3aed,color:#3b0764,font-weight:bold
    classDef ingest   fill:#ffedd5,stroke:#ea580c,color:#7c2d12,font-weight:bold
    classDef store    fill:#f1f5f9,stroke:#475569,color:#1e293b,font-weight:bold
    classDef pipeline fill:#ccfbf1,stroke:#0d9488,color:#134e4a,font-weight:bold
    classDef events   fill:#fef9c3,stroke:#ca8a04,color:#713f12,font-weight:bold
    classDef ui       fill:#d1fae5,stroke:#059669,color:#064e3b,font-weight:bold

    subgraph USER["User"]
        Landing["Landing Page"]
        Upload["Upload Panel<br/>CSV · PDF"]
    end

    subgraph AUTH["Auth0"]
        Auth0["Auth0<br/>MFA · Sessions"]
        FGA["FGA<br/>action → scope"]
    end

    subgraph INGEST["Ingestion"]
        Parser["File Parser<br/>pdf · papaparse"]
        Classify["Categoriser<br/>Rules + AI"]
    end

    subgraph STORE["Store"]
        UserStore["User Store<br/>Transactions · Score"]
        AgentMemory["Agent Memory<br/>file-backed<br/>30-day expiry"]
    end

    subgraph PIPELINE["Agent Pipeline"]
        Scoring["Scoring Engine"]
        Patterns["Pattern Detector"]
        Insights["Insight Generator<br/>WARNING · POSITIVE<br/>NEUTRAL"]
        RAG["RAG Layer<br/>context + prompts"]
    end

    subgraph OPENCLAW["OpenClaw Events"]
        OCTrigger["Chained Trigger<br/>uploaded → scored<br/>→ insights → improved"]
        WF1["autoInsightOnUpload"]
        WF2["highImpactAlert"]
        WF3["weeklyReport<br/>Vercel Cron<br/>Mon 09:00 UTC"]
        WF4["scoreImprovedCelebration"]
    end

    subgraph UI["Dashboard"]
        Shell["Dashboard Shell<br/>Score · Transactions<br/>Insights"]
        ChatPanel["Agent Chat"]
        SimUI["What-If Simulator"]
        NotifBell["Notification Bell<br/>polls every 60s"]
    end

    class Landing,Upload user
    class Auth0,FGA auth
    class Parser,Classify ingest
    class UserStore,AgentMemory store
    class Scoring,Patterns,Insights,RAG pipeline
    class OCTrigger,WF1,WF2,WF3,WF4 events
    class Shell,ChatPanel,SimUI,NotifBell ui

    Landing --> Auth0
    Auth0 --> FGA
    FGA --> Upload
    Landing --> Parser

    Upload --> Parser
    Parser --> Classify
    Classify --> UserStore
    Upload --> OCTrigger

    OCTrigger --> WF1 & WF2 & WF3 & WF4
    WF1 & WF2 & WF3 & WF4 --> UserStore

    UserStore --> Scoring
    Scoring --> Patterns
    Patterns --> Insights
    Insights --> AgentMemory
    Insights --> RAG
    RAG --> ChatPanel

    UserStore --> Shell
    Shell --> ChatPanel & SimUI & NotifBell
    UserStore --> NotifBell
